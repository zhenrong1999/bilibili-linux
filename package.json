    "@protobuf-ts/runtime-rpc": "^2.11.1",
    "@reduxjs/toolkit": "^2.12.0",
    "antd": "^5.29.3",
    "antd-style": "^3.7.1",
    "get-xpath": "^3.3.0",
    "i18next": "^25.10.10",
    "md5": "^2.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^15.7.4",
    "react-redux": "^9.3.0"
  },
